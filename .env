# LangForge Environment Configuration
# Copy this file to .env and update values

# ── Application ────────────────────────────
APP_NAME=LangForge
APP_VERSION=1.0.0
DEBUG=false

# ── Database ───────────────────────────────
# SQLite (development - no setup required)
DATABASE_URL=sqlite+aiosqlite:///./langforge.db

# PostgreSQL (production - recommended)
# DATABASE_URL=postgresql+asyncpg://langforge:password@localhost:5432/langforge

# ── Authentication ─────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# ── Ollama LLM Server ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2           # Chat model
OLLAMA_EMBEDDING_MODEL=nomic-embed-text   # Embedding model for RAG

# ── FAISS Vector Store ─────────────────────
FAISS_INDEX_PATH=./faiss_indexes

# ── File Uploads ───────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
